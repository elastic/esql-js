{
  "name": "@elastic/esql-definitions",
  "version": "4.14.0",
  "author": "Kibana ES|QL team",
  "description": "Shared definitions for the ES|QL language (commands, functions, operators).",
  "license": "Elastic-2.0",
  "sideEffects": false,
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./commands": {
      "types": "./lib/generated/commands.d.ts",
      "import": "./lib/generated/commands.mjs",
      "require": "./lib/generated/commands.js",
      "default": "./lib/generated/commands.js"
    },
    "./functions": {
      "types": "./lib/generated/functions/index.d.ts",
      "import": "./lib/generated/functions/index.mjs",
      "require": "./lib/generated/functions/index.js",
      "default": "./lib/generated/functions/index.js"
    },
    "./operators": {
      "types": "./lib/generated/operators/index.d.ts",
      "import": "./lib/generated/operators/index.mjs",
      "require": "./lib/generated/operators/index.js",
      "default": "./lib/generated/operators/index.js"
    },
    "./settings": {
      "types": "./lib/generated/settings.d.ts",
      "import": "./lib/generated/settings.mjs",
      "require": "./lib/generated/settings.js",
      "default": "./lib/generated/settings.js"
    },
    "./inline-cast": {
      "types": "./lib/generated/inline_cast.d.ts",
      "import": "./lib/generated/inline_cast.mjs",
      "require": "./lib/generated/inline_cast.js",
      "default": "./lib/generated/inline_cast.js"
    },
    "./promql-functions": {
      "types": "./lib/generated/promql_functions/index.d.ts",
      "import": "./lib/generated/promql_functions/index.mjs",
      "require": "./lib/generated/promql_functions/index.js",
      "default": "./lib/generated/promql_functions/index.js"
    },
    "./promql-operators": {
      "types": "./lib/generated/promql_operators/index.d.ts",
      "import": "./lib/generated/promql_operators/index.mjs",
      "require": "./lib/generated/promql_operators/index.js",
      "default": "./lib/generated/promql_operators/index.js"
    },
    "./function-docs": {
      "types": "./lib/generated/function_docs/index.d.ts",
      "import": "./lib/generated/function_docs/index.mjs",
      "require": "./lib/generated/function_docs/index.js",
      "default": "./lib/generated/function_docs/index.js"
    },
    "./operator-docs": {
      "types": "./lib/generated/operator_docs/index.d.ts",
      "import": "./lib/generated/operator_docs/index.mjs",
      "require": "./lib/generated/operator_docs/index.js",
      "default": "./lib/generated/operator_docs/index.js"
    },
    "./promql-function-docs": {
      "types": "./lib/generated/promql_function_docs/index.d.ts",
      "import": "./lib/generated/promql_function_docs/index.mjs",
      "require": "./lib/generated/promql_function_docs/index.js",
      "default": "./lib/generated/promql_function_docs/index.js"
    },
    "./promql-operator-docs": {
      "types": "./lib/generated/promql_operator_docs/index.d.ts",
      "import": "./lib/generated/promql_operator_docs/index.mjs",
      "require": "./lib/generated/promql_operator_docs/index.js",
      "default": "./lib/generated/promql_operator_docs/index.js"
    },
    "./commandNames": {
      "types": "./lib/commandNames.d.ts",
      "import": "./lib/commandNames.mjs",
      "require": "./lib/commandNames.js",
      "default": "./lib/commandNames.js"
    },
    "./functionNames": {
      "types": "./lib/functionNames.d.ts",
      "import": "./lib/functionNames.mjs",
      "require": "./lib/functionNames.js",
      "default": "./lib/functionNames.js"
    },
    "./keywords": {
      "types": "./lib/keywords.d.ts",
      "import": "./lib/keywords.mjs",
      "require": "./lib/keywords.js",
      "default": "./lib/keywords.js"
    },
    "./temporalUnits": {
      "types": "./lib/temporalUnits.d.ts",
      "import": "./lib/temporalUnits.mjs",
      "require": "./lib/temporalUnits.js",
      "default": "./lib/temporalUnits.js"
    }
  },
  "files": [
    "NOTICE.txt",
    "LICENSE.txt",
    "lib"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": "https://github.com/elastic/esql-js.git",
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:watch": "tsup --watch --onSuccess \"tsc -p tsconfig.build.json\"",
    "generate": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/generate.ts",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "25.2.3",
    "jest": "30.4.2",
    "ts-jest": "29.4.11",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  }
}
