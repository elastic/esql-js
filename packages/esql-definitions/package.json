{
  "name": "@elastic/esql-definitions",
  "version": "4.12.0",
  "author": "Kibana ES|QL team",
  "description": "Shared definitions for the ES|QL language (commands, functions, operators).",
  "license": "Elastic-2.0",
  "sideEffects": false,
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./commandNames": {
      "types": "./lib/commandNames.d.ts",
      "import": "./lib/commandNames.mjs",
      "require": "./lib/commandNames.js",
      "default": "./lib/commandNames.js"
    },
    "./functionNames": {
      "types": "./lib/functionNames.d.ts",
      "import": "./lib/functionNames.mjs",
      "require": "./lib/functionNames.js",
      "default": "./lib/functionNames.js"
    },
    "./keywords": {
      "types": "./lib/keywords.d.ts",
      "import": "./lib/keywords.mjs",
      "require": "./lib/keywords.js",
      "default": "./lib/keywords.js"
    },
    "./temporalUnits": {
      "types": "./lib/temporalUnits.d.ts",
      "import": "./lib/temporalUnits.mjs",
      "require": "./lib/temporalUnits.js",
      "default": "./lib/temporalUnits.js"
    }
  },
  "files": [
    "NOTICE.txt",
    "LICENSE.txt",
    "lib"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": "https://github.com/elastic/esql-js.git",
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:watch": "tsup --watch --onSuccess \"tsc -p tsconfig.build.json\"",
    "test": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  }
}
