// Type-checking config for the codegen scripts (run directly by Node's type
// stripping, so nothing is ever emitted from here). Gives the IDE a project
// for scripts/*.ts — the package tsconfig only includes src/.
{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "rootDir": "..",
    "allowImportingTsExtensions": true,
    "types": ["node", "jest"]
  },
  "include": ["./**/*.ts", "../src/**/*.ts"],
  "exclude": ["../node_modules", "../lib"]
}
