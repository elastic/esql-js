{
  "name": "@elastic/esql-promql-grammar",
  "version": "4.7.0",
  "author": "Kibana ES|QL team",
  "description": "Auto-generated ANTLR4 TypeScript artifacts for the PromQL grammar. Do not edit by hand.",
  "license": "Elastic-2.0",
  "sideEffects": false,
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "NOTICE.txt",
    "LICENSE.txt",
    "lib"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": "https://github.com/elastic/esql-js.git",
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:watch": "tsup --watch --onSuccess \"tsc -p tsconfig.build.json\"",
    "test": "jest",
    "antlr4:deps": "brew bundle --file=../../.buildkite/scripts/antlr4_tools/brewfile",
    "build:antlr4": "yarn build:antlr4:lexer && yarn build:antlr4:parser && ../../.buildkite/scripts/postbuild.sh promql",
    "build:antlr4:parser": "antlr -Dlanguage=TypeScript src/promql_parser.g4",
    "build:antlr4:lexer": "antlr -Dlanguage=TypeScript src/promql_lexer.g4"
  },
  "dependencies": {
    "antlr4": "4.13.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "jest": "30.4.2",
    "ts-jest": "29.4.11",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  }
}
