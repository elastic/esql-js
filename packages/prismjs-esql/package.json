{
  "name": "@elastic/prismjs-esql",
  "version": "4.13.0",
  "author": "Kibana ES|QL team",
  "description": "Prism.js and Refractor ES|QL language syntax definitions for highlighting",
  "license": "MIT",
  "sideEffects": false,
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "NOTICE.txt",
    "LICENSE.txt",
    "lib"
  ],
  "keywords": [
    "esql",
    "prism",
    "prismjs",
    "refractor",
    "es|ql",
    "elastic"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": "https://github.com/elastic/esql-js.git",
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:watch": "tsup --watch --onSuccess \"tsc -p tsconfig.build.json\"",
    "test": "jest"
  },
  "dependencies": {
    "@elastic/esql-definitions": "workspace:^"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "jest": "30.4.2",
    "refractor": "5.0.0",
    "ts-jest": "29.4.11",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  }
}
